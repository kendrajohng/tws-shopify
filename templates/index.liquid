<!--
  ============================================================
    THE WRITING STUDIO — Homepage Template
    File: templates/index.liquid (or sections/main-index.liquid)

    SHOPIFY SETUP INSTRUCTIONS:
    1. Go to Online Store > Themes > Edit Code
    2. Under Templates, click "index.liquid" (or create it)
    3. Paste this entire file
    4. Replace YOUR_CALENDLY_URL with your actual Calendly link
    5. Replace product handle references with your real product handles
    6. Save and preview

    FONTS: Loaded via Google Fonts in layout/theme.liquid
    Add this to your <head> in theme.liquid:
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  ============================================================
-->

<style>
  /* ── CSS CUSTOM PROPERTIES ─────────────────────────────────── */
  :root {

    --yellow:     #E3FD01;
    --black:      #000000;
    --white:      #FFFFFF;
    --off-white:  #F5F5F0;
    --gray-light: #EEEEEA;
    --gray-mid:   #AAAAAA;
    --gray-dark:  #444444;

    --font-display: 'DM Serif Display', Georgia, serif;
    --font-ui:      'Syne', sans-serif;
    --font-body:    'DM Mono', 'Courier New', monospace;

    --max-w: 1200px;
    --pad:   clamp(1.5rem, 5vw, 4rem);
    --radius: 2px;
  }

  /* ── RESET ──────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font-body); background: var(--white); color: var(--black); overflow-x: hidden; }
  img  { max-width: 100%; display: block; }
  a    { color: inherit; text-decoration: none; }
  button { cursor: pointer; border: none; background: none; font-family: inherit; }

  /* ── UTILITY ────────────────────────────────────────────────── */
  .tws-container {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--pad);
  }

  .tws-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray-mid);
  }

  .tws-label--blue { color: var(--black); }
  .tws-label--yellow { color: var(--yellow); }

  /* ── BUTTONS ────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.85rem 1.75rem;
    border-radius: var(--radius);
    transition: all 0.18s ease;
    white-space: nowrap;
  }

  .btn--primary {
    background: var(--black);
    color: var(--white);
    border: 2px solid var(--black);
  }
  .btn--primary:hover {
    background: var(--black);
    border-color: var(--black);
    transform: translateY(-1px);
  }

  .btn--yellow {
    background: var(--yellow);
    color: var(--black);
    border: 2px solid var(--yellow);
  }
  .btn--yellow:hover {
    background: var(--black);
    color: var(--yellow);
    border-color: var(--black);
    transform: translateY(-1px);
  }

  .btn--outline {
    background: transparent;
    color: var(--black);
    border: 2px solid var(--black);
  }
  .btn--outline:hover {
    background: var(--black);
    color: var(--white);
    transform: translateY(-1px);
  }

  .btn--outline-white {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
  }
  .btn--outline-white:hover {
    background: var(--white);
    color: var(--black);
  }


  /* ── VSL VIDEO ───────────────────────────────────────────────── */
  .tws-vsl {
    background: var(--white);
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--gray-light);
  }

  .tws-vsl__heading {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--black);
    max-width: 720px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .tws-vsl__embed {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .tws-vsl__footer {
    text-align: center;
    margin-top: 2rem;
  }

  .tws-vsl__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .tws-vsl__placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 30px,
      rgba(227,253,1,0.04) 30px,
      rgba(227,253,1,0.04) 31px
    );
  }

  .tws-vsl__play {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
    transition: transform 0.2s;
  }

  .tws-vsl__play:hover { transform: scale(1.04); }

  .tws-vsl__play-icon {
    width: 64px;
    height: 64px;
    background: var(--yellow);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--black);
    flex-shrink: 0;
  }

  .tws-vsl__play-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  .tws-vsl__play-duration {
    display: block;
    font-size: 0.7rem;
    color: var(--gray-mid);
    letter-spacing: 0.08em;
  }



  /* ── NAV ────────────────────────────────────────────────────── */
  .tws-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: var(--black);
    border-bottom: 1px solid #1a1a1a;
    transition: all 0.3s ease;
  }

  .tws-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 var(--pad);
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .tws-nav__logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tws-nav__mark {
    width: 36px;
    height: 36px;
    background: var(--yellow);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 3px;
    flex-shrink: 0;
  }

  .tws-nav__cursors {
    display: flex;
    gap: 5px;
  }

  .tws-nav__cursor {
    width: 5px;
    height: 9px;
    border: 1.5px solid var(--black);
    border-radius: 1px;
  }

  .tws-nav__wordmark {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: 0.04em;
  }

  .tws-nav__links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .tws-nav__links a {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-mid);
    transition: color 0.15s;
  }
  .tws-nav__links a:hover { color: var(--white); }

  .tws-nav__cta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tws-nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }
  .tws-nav__hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--white);
    transition: all 0.2s;
  }

  /* ── MOBILE NAV ─────────────────────────────────────────────── */
  .tws-mobile-nav {
    display: none;
    position: fixed;
    top: 64px; left: 0; right: 0;
    background: var(--black);
    border-bottom: 1px solid #1a1a1a;
    z-index: 99;
    padding: 1.5rem var(--pad);
    flex-direction: column;
    gap: 1rem;
  }

  .tws-mobile-nav.open { display: flex; }
  .tws-mobile-nav a {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-mid);
    padding: 0.5rem 0;
    border-bottom: 1px solid #1a1a1a;
    transition: color 0.15s;
  }
  .tws-mobile-nav a:hover { color: var(--white); }

  /* ── MARQUEE ─────────────────────────────────────────────────── */
  .tws-marquee {
    background: var(--yellow);
    padding: 0.85rem 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .tws-marquee__track {
    display: inline-flex;
    gap: 0;
    animation: marquee 48s linear infinite;
  }

  .tws-marquee__track span {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--black);
    padding: 0 2rem;
  }

  .tws-marquee__track span::after {
    content: '·';
    margin-left: 2rem;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── SERVICES ────────────────────────────────────────────────── */
  .tws-services {
    padding: 6rem 0;
    background: var(--white);
  }

  .tws-section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3.5rem;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .tws-section-title {
    color: var(--black);
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--black);
  }

  .tws-section-title em {
    font-style: italic;
    color: var(--black);
  }

  .tws-services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--black);
  }

  .tws-service-card {
    padding: 2.5rem 2rem;
    border-right: 1px solid var(--black);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .tws-service-card:last-child { border-right: none; }

  .tws-service-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: var(--black);
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: left;
  }

  .tws-service-card:hover::before { transform: scaleX(1); }
  .tws-service-card:hover { background: var(--off-white); }

  .tws-service-card__num {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--black);
    text-transform: uppercase;
  }

  .tws-service-card__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--black);
    line-height: 1.1;
  }

  .tws-service-card__desc {
    font-size: 0.8rem;
    line-height: 1.8;
    color: var(--gray-dark);
    flex: 1;
  }

  .tws-service-card__price {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--black);
    letter-spacing: 0.06em;
  }

  .tws-service-card__link {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--black);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap 0.15s;
  }
  .tws-service-card__link:hover { gap: 0.7rem; }

  /* ── THESIS ──────────────────────────────────────────────────── */
  .tws-thesis {
    background: var(--black);
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .tws-thesis::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 40%;
    height: 100%;
    background: var(--black);
    clip-path: polygon(15% 0, 100% 0, 100% 100%, 0% 100%);
    opacity: 0.12;
  }

  .tws-thesis__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .tws-thesis__quote {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--white);
    line-height: 1.2;
  }

  .tws-thesis__quote span { color: var(--yellow); }

  .tws-thesis__right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tws-thesis__body {
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--gray-mid);
  }

  .tws-thesis__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tws-thesis__pill {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0.9rem;
    border: 1px solid #333;
    color: var(--gray-mid);
    border-radius: var(--radius);
  }

  /* ── BOOK A CALL ─────────────────────────────────────────────── */
  .tws-booking {
    padding: 6rem 0;
    background: var(--yellow);
    position: relative;
    overflow: hidden;
  }

  .tws-booking::after {
    content: '';
    position: absolute;
    bottom: 0; right: 0;
    width: 300px;
    height: 300px;
    background: var(--black);
    border-radius: 50%;
    transform: translate(40%, 40%);
    opacity: 0.06;
  }

  .tws-booking__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .tws-booking__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    color: var(--black);
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .tws-booking__title em {
    font-style: italic;
    color: var(--black);
  }

  .tws-booking__body {
    font-size: 0.85rem;
    line-height: 1.9;
    color: rgba(0,0,0,0.65);
    margin-bottom: 2rem;
  }

  .tws-booking__details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tws-booking__detail {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: rgba(0,0,0,0.75);
  }

  .tws-booking__detail-icon {
    width: 28px;
    height: 28px;
    background: rgba(0,0,0,0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .tws-booking__widget {
    background: var(--white);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tws-booking__widget-title {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--black);
  }

  .tws-booking__widget-body {
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--gray-dark);
  }

  .tws-booking__widget-items {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .tws-booking__widget-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    color: var(--gray-dark);
  }

  .tws-booking__widget-item::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--black);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── WHY US ──────────────────────────────────────────────────── */
  .tws-why {
    padding: 6rem 0;
    background: var(--white);
  }

  .tws-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--black);
  }

  .tws-why__card {
    padding: 2.5rem 2rem;
    border-right: 1px solid var(--black);
    border-bottom: 1px solid var(--black);
    position: relative;
  }

  .tws-why__card:nth-child(3n) { border-right: none; }
  .tws-why__card:nth-last-child(-n+3) { border-bottom: none; }

  .tws-why__num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--gray-mid);
    line-height: 1;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }

  .tws-why__card:hover .tws-why__num { color: var(--black); }


  .tws-why__card-title {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--black);
    margin-bottom: 0.75rem;
  }

  .tws-why__card-body {
    font-size: 0.8rem;
    line-height: 1.8;
    color: var(--gray-dark);
  }

  /* ── STUDIO STATS ────────────────────────────────────────────── */
  .tws-stats {
    padding: 4rem 0;
    background: var(--black);
  }

  .tws-stats__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .tws-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 4rem;
    text-align: center;
  }

  .tws-stats__num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: var(--yellow);
    line-height: 1;
  }

  .tws-stats__label {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-mid);
  }

  .tws-stats__divider {
    width: 1px;
    height: 60px;
    background: #222;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .tws-stats__grid { flex-direction: column; }
    .tws-stats__divider { width: 40px; height: 1px; }
    .tws-stats__item { padding: 1rem 2rem; }
  }

  /* ── FOOTER ──────────────────────────────────────────────────── */
  .tws-footer {
    background: var(--black);
    border-top: 1px solid #1a1a1a;
    padding: 4rem 0 2rem;
  }

  .tws-footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 2rem;
  }

  .tws-footer__brand p {
    font-size: 0.78rem;
    line-height: 1.8;
    color: var(--gray-mid);
    margin-top: 1rem;
    max-width: 280px;
  }

  .tws-footer__logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tws-footer__logo-mark {
    width: 40px;
    height: 40px;
    background: var(--yellow);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }

  .tws-footer__logo-cursors { display: flex; gap: 6px; }
  .tws-footer__logo-cursor {
    width: 6px;
    height: 11px;
    border: 1.5px solid var(--black);
    border-radius: 1px;
  }

  .tws-footer__logo-text {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--white);
  }

  .tws-footer__col-title {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gray-mid);
    margin-bottom: 1.25rem;
  }

  .tws-footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tws-footer__links a {
    font-size: 0.8rem;
    color: #555;
    transition: color 0.15s;
  }
  .tws-footer__links a:hover { color: var(--white); }

  .tws-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .tws-footer__copy {
    font-size: 0.72rem;
    color: #333;
    letter-spacing: 0.06em;
  }

  .tws-footer__legal {
    display: flex;
    gap: 1.5rem;
  }
  .tws-footer__legal a {
    font-size: 0.72rem;
    color: #333;
    transition: color 0.15s;
  }
  .tws-footer__legal a:hover { color: var(--gray-mid); }

  /* ── SCROLL REVEAL ───────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .tws-nav__links,
    .tws-nav__cta .btn--outline-white { display: none; }
